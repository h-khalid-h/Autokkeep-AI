{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/plaid-sync",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/auto-categorize",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/suspense-timeout",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/receipt-chase",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/cron/token-refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/ledger-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 16 * * 5"
    }
  ]
}
