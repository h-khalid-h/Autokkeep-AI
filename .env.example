# ═══════════════════════════════════════════════════════════════════════════════
# Autokkeep Environment Variables
# Copy this file to .env.local and fill in the values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase (Required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── AI Engine (Required for categorization) ─────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ─── Banking: Plaid ──────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=https://your-domain.com/api/webhooks/plaid
PLAID_SKIP_WEBHOOK_VERIFICATION=false

# ─── Ledger: QuickBooks Online ───────────────────────────────────────────────
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=https://your-domain.com/api/ledger/quickbooks/auth
QBO_ENVIRONMENT=sandbox

# ─── Ledger: Xero ────────────────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://your-domain.com/api/ledger/xero/auth

# ─── Billing: Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ─── Email: Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@autokkeep.com

# ─── Messaging: Slack ────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# ─── Messaging: Microsoft Teams ──────────────────────────────────────────────
TEAMS_WEBHOOK_URL=
TEAMS_WEBHOOK_SECRET=

# ─── Messaging: Twilio (SMS + WhatsApp) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...
TWILIO_WHATSAPP_NUMBER=+1...

# ─── Security ────────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=
CRON_SECRET=
ADMIN_EMAILS=admin@example.com

# ─── Caching (Optional) ─────────────────────────────────────────────────────
REDIS_URL=

# ─── Monitoring (Optional) ───────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── OCR (Optional) ─────────────────────────────────────────────────────────
OCR_LOOKBACK_DAYS=30
