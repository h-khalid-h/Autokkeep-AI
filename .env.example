# ============================================
# AUTOKKEEP — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
#
#   cp .env.example .env.local
#
# Required vars are marked with [REQUIRED].
# Optional vars have sensible defaults or are only needed
# if you enable the corresponding integration.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Supabase  [REQUIRED]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Project URL and anon key (public, safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — server-side only, bypasses RLS
# Used by webhook handlers and admin operations
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenAI  [REQUIRED for AI Categorization]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OPENAI_API_KEY=sk-your_openai_key
# Model to use — defaults to gpt-4o if not set
OPENAI_MODEL=gpt-4o

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Plaid  [REQUIRED for Bank Integrations]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# Environment: sandbox | development | production
PLAID_ENV=sandbox

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Stripe  [REQUIRED for Billing]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Price IDs for each plan tier (create these in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_SMB_GROWTH=price_xxx
STRIPE_PRICE_ID_CPA_PROFESSIONAL=price_xxx
STRIPE_PRICE_ID_CPA_ENTERPRISE=price_xxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Slack  [Optional — Messaging Channel]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Microsoft Teams  [Optional — Messaging Channel]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TEAMS_WEBHOOK_URL=your_teams_incoming_webhook_url
# HMAC secret for verifying Teams outgoing webhook requests
TEAMS_WEBHOOK_SECRET=your_teams_webhook_secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Twilio  [Optional — SMS + WhatsApp]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# QuickBooks Online  [Optional — Ledger Sync]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret
# ⚠️ Update to production URL before deploying
QBO_REDIRECT_URI=http://localhost:3000/api/ledger/quickbooks/callback
# Environment: sandbox | production
QBO_ENVIRONMENT=sandbox

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Xero  [Optional — Ledger Sync]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
# ⚠️ Update to production URL before deploying
XERO_REDIRECT_URI=http://localhost:3000/api/ledger/xero/callback

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Cron Jobs  [Optional — Automated Sync]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Secret token to authenticate cron job requests (e.g. /api/cron/plaid-sync)
CRON_SECRET=your_cron_secret_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Resend  [Optional — Email Notifications]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API key for transactional email (weekly digest, high-risk alerts)
RESEND_API_KEY=re_your_resend_api_key
# From address (must match verified domain in Resend)
RESEND_FROM_EMAIL=Autokkeep <noreply@yourdomain.com>

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis  [Optional — Caching & Rate Limiting]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠️ Update to production URL before deploying
REDIS_URL=redis://localhost:6379

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Sentry  [Optional — Error Tracking]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get a DSN from sentry.io after creating a Next.js project
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Token Encryption  [Optional — OAuth Security]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 32-byte hex key for encrypting OAuth tokens (QBO, Xero) at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, tokens are stored in plaintext (backward compatible)
TOKEN_ENCRYPTION_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# App Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Public base URL — used for OAuth redirects, webhook URLs, etc.
# ⚠️ Update to production URL before deploying
NEXT_PUBLIC_APP_URL=http://localhost:3000
