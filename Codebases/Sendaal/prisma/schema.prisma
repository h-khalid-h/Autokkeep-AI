// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model for account holders
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  handle        String   @unique
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  paymentRequests  PaymentRequest[] @relation("CreatedBy")
  receivedPayments PaymentRequest[] @relation("ReceivedBy")
  transactions     Transaction[]

  @@index([email])
  @@index([handle])
}

// Waitlist for early access
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  handle    String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Payment Request (the "Sendaal Link")
model PaymentRequest {
  id              String            @id @default(cuid())
  amount          Decimal           @db.Decimal(19, 4) // Exact precision for money
  currency        String            @db.VarChar(3) // ISO 4217 (USD, EUR, etc.)
  description     String?
  status          PaymentStatus     @default(PENDING)
  
  // Creator (person requesting payment)
  creatorId       String
  creator         User              @relation("CreatedBy", fields: [creatorId], references: [id])
  
  // Recipient (person being paid)
  recipientId     String?
  recipient       User?             @relation("ReceivedBy", fields: [recipientId], references: [id])
  recipientHandle String            // Handle even if no account yet
  recipientName   String?
  
  // Payment method selected
  paymentMethod   PaymentMethod?
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  expiresAt       DateTime?
  
  // Relations
  transactions    Transaction[]

  @@index([creatorId, status])
  @@index([recipientId, status])
  @@index([createdAt])
}

// Immutable Transaction Ledger
model Transaction {
  id                String            @id @default(cuid())
  
  // Link to payment request
  paymentRequestId  String
  paymentRequest    PaymentRequest    @relation(fields: [paymentRequestId], references: [id])
  
  // Financial details (immutable once created)
  amount            Decimal           @db.Decimal(19, 4)
  currency          String            @db.VarChar(3)
  status            TransactionStatus @default(PENDING)
  
  // Parties involved
  fromUserId        String?
  fromUser          User?             @relation(fields: [fromUserId], references: [id])
  toHandle          String            // Always record the recipient handle
  
  // Settlement
  settlementTime    DateTime?
  
  // Cryptographic proof
  signature         String            // SHA-256 hash of transaction data
  idempotencyKey    String            @unique // Prevent double payments
  
  // Provider data (Stripe, Circle, etc.)
  providerType      String?           // "stripe", "circle", "internal"
  providerTxId      String?           // External transaction ID
  
  // Metadata
  metadata          Json?             // Flexible data storage
  
  // Audit trail
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([paymentRequestId, status])
  @@index([fromUserId])
  @@index([createdAt])
  @@index([status, settlementTime])
}

// Enums
enum PaymentStatus {
  PENDING      // Link created, awaiting payment
  PROCESSING   // Payment initiated
  SETTLED      // Money transferred
  FAILED       // Payment failed
  EXPIRED      // Link expired
  CANCELLED    // Cancelled by creator
}

enum TransactionStatus {
  PENDING      // Transaction initiated
  SETTLED      // Funds confirmed
  FAILED       // Transaction failed
  REFUNDED     // Money returned
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  CRYPTO
  BANK_TRANSFER
}
